class MapaVisual extends StatefulWidget {
  final String? archivoJson;
  final String? nodoInicialOverride;
  final Map<String, dynamic>? datosDirectos;

  const MapaVisual({super.key, required this.archivoJson, this.nodoInicialOverride, this.datosDirectos});

  @override
  State<MapaVisual> createState() => _MapaVisualState();
}

class _MapaVisualState extends State<MapaVisual> with TickerProviderStateMixin {
  String get _idParaNotas {
    // Si tenemos nombre de archivo, lo usamos.
    // Si no, usamos el título del algoritmo.
    // Si aun no cargó, usamos "temp".
    return widget.archivoJson ?? algoritmo?.titulo ?? "algoritmo_temp";
  }
  AlgoritmoMedico? algoritmo;
  List<NodoEnElMapa> nodosVisibles = [];
  final List<Matrix4> _historialCamara = [];
  List<NodoEnElMapa> _ultimoGrupoHijos = [];
  final List<List<NodoEnElMapa>> _historialNavegacion = [];
  int _indiceHijoNavegacion = -1;
  double _zoomLevelActual = 0.8;
  final TransformationController _controller = TransformationController();
  final GlobalKey<ScaffoldState> _scaffoldKey = GlobalKey<ScaffoldState>();

  bool primeraVez = true;
  bool cargando = true;
  List<Nota> notasDelAlgoritmo = [];

  bool modoAutomatico = true;
  late AnimationController _camaraController;
  Animation<Matrix4>? _camaraAnimation;

  @override
  void initState() {
    super.initState();
    _camaraController = AnimationController(vsync: this, duration: const Duration(milliseconds: 800));
    cargarDatos();
  }

  @override
  void dispose() {
    _controller.dispose();
    _camaraController.dispose();
    super.dispose();
  }

  void _cambiarZoomManual(double nuevoZoom) {
    final size = MediaQuery.of(context).size;
    Matrix4 currentMatrix = _controller.value;

    double centerX = (size.width / 2 - currentMatrix.getTranslation().x) / currentMatrix.getMaxScaleOnAxis();
    double centerY = (size.height / 2 - currentMatrix.getTranslation().y) / currentMatrix.getMaxScaleOnAxis();

    double tx = (size.width / 2) - (centerX * nuevoZoom);
    double ty = (size.height / 2) - (centerY * nuevoZoom);

    final newMatrix = Matrix4.identity()
      ..translate(tx, ty)
      ..scale(nuevoZoom);

    _controller.value = newMatrix;
    setState(() => _zoomLevelActual = nuevoZoom);
  }

  void _animarHaciaMatriz(Matrix4 destino) {
    _camaraAnimation = Matrix4Tween(
      begin: _controller.value,
      end: destino,
    ).animate(CurvedAnimation(parent: _camaraController, curve: Curves.easeOutCubic));

    _camaraAnimation!.addListener(() {
      if (mounted) {
        setState(() {
          _controller.value = _camaraAnimation!.value;
        });
      }
    });

    _camaraController.reset();
    _camaraController.forward();
  }

  void _enfocarRaizInicial() {
    if (!modoAutomatico) return;
    WidgetsBinding.instance.addPostFrameCallback((_) {
      if (!mounted) return;
      final size = MediaQuery.of(context).size;
      double zoom = 0.9;
      double targetX = 2500.0;
      double targetY = 2500.0;

      double tx = (size.width / 2) - (targetX * zoom);
      double ty = (size.height / 3.5) - (targetY * zoom);

      final matrix = Matrix4.identity()
        ..translate(tx, ty)
        ..scale(zoom);

      _animarHaciaMatriz(matrix);
    });
  }

  void _enfocarNuevoGrupo(NodoEnElMapa padre, List<NodoEnElMapa> nuevosHijos) {
    if (!modoAutomatico || nuevosHijos.isEmpty) return;

    // 1. GUARDAR HISTORIALES
    _historialCamara.add(_controller.value);
    _historialNavegacion.add(List.from(_ultimoGrupoHijos));

    // 2. ACTUALIZAR ESTADO ACTUAL
    _ultimoGrupoHijos = nuevosHijos;
    _indiceHijoNavegacion = -1;

    final size = MediaQuery.of(context).size;

    double minAnchorX = double.infinity;
    double maxAnchorX = double.negativeInfinity;

    for (var n in nuevosHijos) {
      if (n.x < minAnchorX) minAnchorX = n.x;
      if (n.x > maxAnchorX) maxAnchorX = n.x;
    }

    double leftEdge = minAnchorX - 130;
    double rightEdge = maxAnchorX + 130;
    double anchoGrupoReal = rightEdge - leftEdge;

    double centroGrupoX = (leftEdge + 2500) + (anchoGrupoReal / 2);

    double yPadre = padre.y + 2500;
    double yHijos = nuevosHijos.first.y + 2500;

    double margenSeguridad = 100.0;
    double factorZoom = size.width / (anchoGrupoReal + margenSeguridad);
    factorZoom = factorZoom.clamp(0.4, 1.0);

    setState(() {
      _zoomLevelActual = factorZoom;
    });

    double targetX = centroGrupoX;
    double targetY = yPadre + ((yHijos - yPadre) * 0.9);

    double tx = (size.width / 2) - (targetX * factorZoom);
    double ty = (size.height / 2) - (targetY * factorZoom);

    final matrix = Matrix4.identity()
      ..translate(tx, ty)
      ..scale(factorZoom);

    _animarHaciaMatriz(matrix);
  }

  void aplicarFiltro(NodoEnElMapa nodo, int? indiceFiltro) {
    setState(() {
      int index = nodosVisibles.indexOf(nodo);
      if (index == -1) return;

      nodosVisibles[index] = NodoEnElMapa(
        id: nodo.id,
        data: nodo.data,
        x: nodo.x,
        y: nodo.y,
        nivel: nodo.nivel,
        padreId: nodo.padreId,
        padreX: nodo.padreX,
        padreY: nodo.padreY,
        textoConector: nodo.textoConector,
        rankingCalculado: nodo.rankingCalculado,
        filtroHijoIndex: indiceFiltro,
        esDestino: nodo.esDestino,
        yaRevelado: nodo.yaRevelado,
      );
      ocultarHijos(nodo);
      Future.delayed(const Duration(milliseconds: 50), () {
        revelarHijos(nodosVisibles[index]);
      });
    });
  }

  void _enfocarHijoEspecifico(int index) {
    if (_ultimoGrupoHijos.isEmpty) return;

    if (index >= _ultimoGrupoHijos.length) index = 0;
    if (index < 0) index = _ultimoGrupoHijos.length - 1;

    setState(() {
      _indiceHijoNavegacion = index;
    });

    NodoEnElMapa nodoTarget = _ultimoGrupoHijos[index];
    final size = MediaQuery.of(context).size;

    double zoomLectura = 1.0;
    double targetX = nodoTarget.x + 2500;

    double targetY = nodoTarget.y + 2500 + 225;

    double tx = (size.width / 2) - (targetX * zoomLectura);
    double ty = (size.height / 2) - (targetY * zoomLectura);

    final matrix = Matrix4.identity()
      ..translate(tx, ty)
      ..scale(zoomLectura);

    setState(() => _zoomLevelActual = zoomLectura);

    _animarHaciaMatriz(matrix);
  }

  void cargarDatos() async {
    final datos = await CargadorAssets.cargarAlgoritmo(_idParaNotas);
    AlgoritmoMedico? datosCargados;

    if (widget.datosDirectos != null) {
      // Necesitamos una función en CargadorAssets que convierta Map -> Objeto
      // O podemos hacerlo aquí directo si no quieres tocar CargadorAssets
      datosCargados = AlgoritmoMedico.fromJson(widget.datosDirectos!);
    }
    // CASO B: Vengo de un enlace interno o legado (Local)
    else if (widget.archivoJson != null) {
      datosCargados = await CargadorAssets.cargarAlgoritmo(widget.archivoJson!);
    }

    if (datosCargados == null) return; // Error de seguridad

    await _refrescarNotas();
    _historialCamara.clear();
    _historialNavegacion.clear();

    setState(() {
      algoritmo = datosCargados;
      int cantidad = datos.nodosIniciales.length;
      double espacio = 500.0;
      double inicioX = -((cantidad - 1) * espacio) / 2;
      for (int i = 0; i < cantidad; i++) {
        String idDelNodo = datos.nodosIniciales[i];
        if (datos.nodos[idDelNodo] != null) {
          nodosVisibles.add(
            NodoEnElMapa(id: idDelNodo, data: datos.nodos[idDelNodo]!, x: inicioX + (i * espacio), y: 0, nivel: 0),
          );
        }
      }
      cargando = false;
    });

    if (primeraVez) {
      if (widget.nodoInicialOverride != null) {
        Future.delayed(const Duration(milliseconds: 500), () {
          _ejecutarNavegacionProfunda(widget.nodoInicialOverride!);
        });
      } else {
        Future.delayed(const Duration(milliseconds: 100), _enfocarRaizInicial);
      }
      primeraVez = false;
    }
  }

  void _ejecutarNavegacionProfunda(String idObjetivo) async {
    if (algoritmo == null) return;
    List<String>? caminoEncontrado;

    for (String raiz in algoritmo!.nodosIniciales) {
      caminoEncontrado = _buscarCamino(raiz, idObjetivo, []);
      if (caminoEncontrado != null) break;
    }

    if (caminoEncontrado == null) {
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(const SnackBar(content: Text("No se encontró la ruta al nodo objetivo.")));
      }
      return;
    }

    for (int i = 0; i < caminoEncontrado.length - 1; i++) {
      String idPadre = caminoEncontrado[i];
      try {
        NodoEnElMapa nodoPadreVisual = nodosVisibles.firstWhere((n) => n.id == idPadre);

        if (!nodoPadreVisual.yaRevelado) {
          revelarHijos(nodoPadreVisual);
          await Future.delayed(const Duration(milliseconds: 900));
        }
      } catch (e) {
        debugPrint("Error en navegación automática: $e");
      }
    }

    if (mounted) {
      setState(() {
        try {
          int index = nodosVisibles.indexWhere((n) => n.id == idObjetivo);
          if (index != -1) {
            var nodo = nodosVisibles[index];
            nodosVisibles[index] = NodoEnElMapa(
              id: nodo.id,
              data: nodo.data,
              x: nodo.x,
              y: nodo.y,
              nivel: nodo.nivel,
              padreId: nodo.padreId,
              padreX: nodo.padreX,
              padreY: nodo.padreY,
              textoConector: nodo.textoConector,
              rankingCalculado: nodo.rankingCalculado,
              filtroHijoIndex: nodo.filtroHijoIndex,
              esDestino: true,
              yaRevelado: nodo.yaRevelado,
            );
          }
        } catch (e) {}
      });
    }
  }

  List<String>? _buscarCamino(String actual, String objetivo, List<String> rutaActual) {
    rutaActual.add(actual);
    if (actual == objetivo) return List.from(rutaActual);

    if (algoritmo!.nodos[actual] != null) {
      for (var opcion in algoritmo!.nodos[actual]!.opciones) {
        var resultado = _buscarCamino(opcion.siguienteNodo, objetivo, rutaActual);
        if (resultado != null) return resultado;
      }
    }
    rutaActual.removeLast();
    return null;
  }

  Future<void> _refrescarNotas() async {
    var lista = await ServicioNotas.obtenerNotasPorAlgoritmo(_idParaNotas);
    setState(() {
      notasDelAlgoritmo = lista;
    });
  }

  void _abrirCrearNotaNodo(String nodoId, String textoNodo) {
    String etiqueta = textoNodo.length > 20 ? "${textoNodo.substring(0, 20)}..." : textoNodo;
    Nota? notaPrevia;
    try {
      notaPrevia = notasDelAlgoritmo.firstWhere((n) => n.nodoId == nodoId);
    } catch (e) {
      notaPrevia = null;
    }

    final tituloCtrl = TextEditingController(text: notaPrevia?.titulo ?? "");
    final contenidoCtrl = TextEditingController(text: notaPrevia?.contenido ?? "");

    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        title: Text(notaPrevia == null ? "Nota en: $etiqueta" : "Editar Nota"),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            TextField(
              controller: tituloCtrl,
              decoration: const InputDecoration(labelText: "Título"),
            ),
            const SizedBox(height: 10),
            TextField(
              controller: contenidoCtrl,
              decoration: const InputDecoration(labelText: "Contenido", border: OutlineInputBorder()),
              maxLines: 3,
            ),
          ],
        ),
        actions: [
          TextButton(onPressed: () => Navigator.pop(context), child: const Text("Cancelar")),
          ElevatedButton(
            onPressed: () async {
              if (tituloCtrl.text.isEmpty) return;
              final nuevaNota = Nota(
                id: notaPrevia?.id ?? DateTime.now().millisecondsSinceEpoch.toString(),
                titulo: tituloCtrl.text,
                contenido: contenidoCtrl.text,
                fecha: DateFormat('dd MMM - HH:mm').format(DateTime.now()),
                archivoJson: _idParaNotas,
                nombreAlgoritmo: algoritmo?.titulo ?? "Algoritmo",
                esPediatrico: ConfiguracionApp.esModoPediatria,
                nodoId: nodoId,
                nodoEtiqueta: etiqueta,
              );
              await ServicioNotas.guardarNota(nuevaNota);
              _refrescarNotas();
              Navigator.pop(context);
              ScaffoldMessenger.of(context).showSnackBar(const SnackBar(content: Text("Nota guardada")));
            },
            child: const Text("Guardar"),
          ),
        ],
      ),
    );
  }

  void revelarHijos(NodoEnElMapa nodoPadre) {
    if (nodoPadre.yaRevelado) {
      ocultarHijos(nodoPadre);
      return;
    }

    List<Map<String, dynamic>> candidatos = [];
    for (var opcion in nodoPadre.data.opciones) {
      var nodoHijo = algoritmo!.nodos[opcion.siguienteNodo];
      if (nodoHijo != null) {
        candidatos.add({
          'nodo': nodoHijo,
          'id': opcion.siguienteNodo,
          'textoConector': opcion.texto,
          'numReferencias': nodoHijo.referencias.length,
          'originalIndex': nodoPadre.data.opciones.indexOf(opcion),
        });
      }
    }

    if (candidatos.isEmpty) return;

    if (nodoPadre.filtroHijoIndex != null) {
      candidatos = candidatos.where((c) => c['originalIndex'] == nodoPadre.filtroHijoIndex).toList();
    }

    candidatos.sort((a, b) {
      int refsA = a['numReferencias'];
      int refsB = b['numReferencias'];
      return refsB.compareTo(refsA);
    });

    Map<String, int> mapaRankings = {};
    var listaParaRanking = List<Map<String, dynamic>>.from(candidatos);
    listaParaRanking.sort((a, b) => b['numReferencias'].compareTo(a['numReferencias']));

    for (int i = 0; i < listaParaRanking.length; i++) {
      if (listaParaRanking[i]['nodo'].tipo == 'resultado' && listaParaRanking[i]['numReferencias'] > 0) {
        mapaRankings[listaParaRanking[i]['id']] = i + 1;
      } else {
        mapaRankings[listaParaRanking[i]['id']] = 0;
      }
    }

    double espacioVertical = 320.0;
    if (nodoPadre.data.texto.length > 120) espacioVertical += 200.0;
    if (nodoPadre.data.imagenClinica != null) espacioVertical += 150.0;
    if (nodoPadre.data.enlaces.isNotEmpty || nodoPadre.data.calculadoraArchivo != null) espacioVertical += 50.0;

    double anchoNodoVisual = 250.0;
    double margenEntreNodos = 50.0;
    double anchoTotalNodo = anchoNodoVisual + margenEntreNodos;
    double nivelHijosY = nodoPadre.y + espacioVertical;

    int cantidadHijos = candidatos.length;
    double anchoTotalCluster = (cantidadHijos * anchoTotalNodo) - margenEntreNodos;

    double centroIdealX = nodoPadre.x + (anchoNodoVisual / 2);
    double inicioxIdeal = centroIdealX - (anchoTotalCluster / 2);
    double finxIdeal = inicioxIdeal + anchoTotalCluster;

    double zonaHijosTop = nivelHijosY;
    double zonaHijosBottom = nivelHijosY + 450.0;

    List<NodoEnElMapa> obstaculos = nodosVisibles.where((n) {
      if (n.id == nodoPadre.id) return false;
      double nTop = n.y;
      double nBottom = n.y + 450.0;
      bool solapaVertical = (nTop < zonaHijosBottom && nBottom > zonaHijosTop);
      return solapaVertical;
    }).toList();

    List<List<double>> intervalosOcupados = [];
    double paddingSeguridad = 100.0;

    for (var obs in obstaculos) {
      double obsMin = obs.x - paddingSeguridad;
      double obsMax = obs.x + anchoNodoVisual + paddingSeguridad;
      intervalosOcupados.add([obsMin, obsMax]);
    }

    double mejorInicioX = inicioxIdeal;
    bool hayColision = _verificaColision(inicioxIdeal, finxIdeal, intervalosOcupados);

    if (hayColision) {
      List<double> puntosCandidatos = [];
      for (var intervalo in intervalosOcupados) {
        puntosCandidatos.add(intervalo[0] - anchoTotalCluster);
        puntosCandidatos.add(intervalo[1]);
      }
      puntosCandidatos.sort((a, b) {
        double distA = ((a + anchoTotalCluster / 2) - centroIdealX).abs();
        double distB = ((b + anchoTotalCluster / 2) - centroIdealX).abs();
        return distA.compareTo(distB);
      });
      for (double punto in puntosCandidatos) {
        if (!_verificaColision(punto, punto + anchoTotalCluster, intervalosOcupados)) {
          mejorInicioX = punto;
          break;
        }
      }
      if (_verificaColision(mejorInicioX, mejorInicioX + anchoTotalCluster, intervalosOcupados)) {
        double maxX = intervalosOcupados.fold(0, (max, i) => i[1] > max ? i[1] : max);
        mejorInicioX = maxX + 50;
      }
    }

    List<NodoEnElMapa> nuevosHijos = [];

    setState(() {
      nodoPadre.yaRevelado = true;
      for (int i = 0; i < cantidadHijos; i++) {
        var candidato = candidatos[i];
        String idHijo = candidato['id'];

        double posX = mejorInicioX + (i * anchoTotalNodo);

        var nuevoNodo = NodoEnElMapa(
          id: idHijo,
          data: candidato['nodo'],
          x: posX,
          y: nivelHijosY,
          nivel: nodoPadre.nivel + 1,
          padreId: nodoPadre.id,
          padreX: nodoPadre.x,
          padreY: nodoPadre.y,
          textoConector: candidato['textoConector'],
          rankingCalculado: mapaRankings[idHijo] ?? 0,
        );
        nodosVisibles.add(nuevoNodo);
        nuevosHijos.add(nuevoNodo);
      }

      if (nuevosHijos.isNotEmpty) {
        WidgetsBinding.instance.addPostFrameCallback((_) {
          _enfocarNuevoGrupo(nodoPadre, nuevosHijos);
        });
      }
    });
  }

  bool _verificaColision(double start, double end, List<List<double>> intervalos) {
    for (var intervalo in intervalos) {
      double occStart = intervalo[0];
      double occEnd = intervalo[1];
      if (start < occEnd && end > occStart) return true;
    }
    return false;
  }

  void ocultarHijos(NodoEnElMapa nodoPadre) {
    setState(() {
      nodoPadre.yaRevelado = false;
      List<String> idsParaBorrar = [];
      void buscarDescendientes(String idPadre) {
        var hijos = nodosVisibles.where((n) => n.padreId == idPadre).toList();
        for (var hijo in hijos) {
          idsParaBorrar.add(hijo.id);
          buscarDescendientes(hijo.id);
        }
      }

      buscarDescendientes(nodoPadre.id);
      nodosVisibles.removeWhere((nodo) => idsParaBorrar.contains(nodo.id));
    });
  }

  void deshacerUltimoNivel() {
    if (nodosVisibles.isEmpty) return;
    int nivelMaximo = nodosVisibles.fold(0, (max, nodo) => nodo.nivel > max ? nodo.nivel : max);
    if (nivelMaximo == 0) return;

    setState(() {
      // 1. Borrar Nodos
      var nodosBorrar = nodosVisibles.where((n) => n.nivel == nivelMaximo).toList();
      for (var nodo in nodosBorrar) {
        try {
          var padre = nodosVisibles.firstWhere((p) => p.id == nodo.padreId);
          padre.yaRevelado = false;
        } catch (_) {}
      }
      nodosVisibles.removeWhere((n) => n.nivel == nivelMaximo);

      // 2. Restaurar Cámara
      if (modoAutomatico && _historialCamara.isNotEmpty) {
        Matrix4 ultimaPosicion = _historialCamara.removeLast();
        _animarHaciaMatriz(ultimaPosicion);
      }

      // 3. NUEVO: Restaurar Navegación (Sincronizar flechas)
      if (modoAutomatico && _historialNavegacion.isNotEmpty) {
        _ultimoGrupoHijos = _historialNavegacion.removeLast();
        _indiceHijoNavegacion = -1;
      } else {
        _ultimoGrupoHijos = [];
        _indiceHijoNavegacion = -1;
      }
    });
  }

  @override
  Widget build(BuildContext context) {
    if (cargando) return const Scaffold(body: Center(child: CircularProgressIndicator()));

    return Scaffold(
      key: _scaffoldKey,
      appBar: AppBar(
        title: Text(algoritmo?.titulo ?? "Mapa"),
        backgroundColor: Colors.teal.shade100,
        actions: [
          IconButton(
            icon: const Icon(Icons.description, color: Colors.teal),
            tooltip: "Ver Notas del Algoritmo",
            onPressed: () => _scaffoldKey.currentState?.openEndDrawer(),
          ),
        ],
      ),
      endDrawer: DrawerNotas(
        archivoJson: _idParaNotas,
        nombreAlgoritmo: algoritmo?.titulo ?? "Algoritmo",
        onNotaGuardada: _refrescarNotas,
      ),
      floatingActionButton: Column(
        mainAxisSize: MainAxisSize.min,
        crossAxisAlignment: CrossAxisAlignment.end,
        children: [
          FloatingActionButton.small(
            heroTag: "null",
            backgroundColor: Colors.white,
            foregroundColor: modoAutomatico ? Colors.teal : Colors.grey,
            child: Icon(modoAutomatico ? Icons.videocam : Icons.videocam_off),
            onPressed: () {
              setState(() {
                modoAutomatico = !modoAutomatico;
              });
              ScaffoldMessenger.of(context).showSnackBar(
                SnackBar(
                  content: Text(modoAutomatico ? "Modo Guiado: Activado" : "Modo Libre: Activado"),
                  duration: const Duration(milliseconds: 600),
                ),
              );
            },
          ),
          const SizedBox(height: 10),
          FloatingActionButton.extended(
            heroTag: "null",
            onPressed: deshacerUltimoNivel,
            label: const Text("Volver"),
            icon: const Icon(Icons.undo),
            backgroundColor: Colors.teal,
            foregroundColor: Colors.white,
          ),
        ],
      ),
      body: LayoutBuilder(
        builder: (context, constraints) {
          // 1. CÁLCULO DE ÁREAS Y LÍNEAS (AHORA ESTÁ EN EL ORDEN CORRECTO)
          List<Rect> areasOcupadas = nodosVisibles.map((n) => Rect.fromLTWH(n.x + 2500 - 120, n.y + 2500, 250.0, 450.0)).toList();

          Map<String, double> midYsPorPadre = {};

          Map<String, List<NodoEnElMapa>> hijosPorPadre = {};
          for (var nodo in nodosVisibles) {
            if (nodo.padreId != null) {
              hijosPorPadre.putIfAbsent(nodo.padreId!, () => []).add(nodo);
            }
          }

          for (var entry in hijosPorPadre.entries) {
            String padreId = entry.key;
            List<NodoEnElMapa> hijos = entry.value;

            double startY = hijos.first.padreY! + 2500 + 100;
            double startX = hijos.first.padreX! + 2500;
            double targetY = hijos.first.y + 2500;

            double maxMidY = startY + (targetY - startY) * 0.5;
            if (maxMidY < startY + 80) maxMidY = startY + 80;

            for (var hijo in hijos) {
              double targetX = hijo.x + 2500;
              double minX = startX < targetX ? startX : targetX;
              double maxX = startX > targetX ? startX : targetX;

              for (var rect in areasOcupadas) {
                if ((rect.center.dx - startX).abs() < 50 && (rect.center.dy - startY - 100).abs() < 200) continue;
                if ((rect.center.dx - targetX).abs() < 50 && (rect.center.dy - targetY).abs() < 200) continue;

                double obsLeft = rect.left - 20;
                double obsRight = rect.right + 20;

                if (obsRight > minX && obsLeft < maxX) {
                  if (maxMidY >= rect.top && maxMidY <= rect.bottom) {
                    if (rect.bottom + 60 > maxMidY) maxMidY = rect.bottom + 60;
                  }
                }
              }
            }
            if (maxMidY > targetY - 40) maxMidY = targetY - 40;
            midYsPorPadre[padreId] = maxMidY;
          }

          // 2. RETORNO DE LA UI (STACK)
          return Stack(
            children: [
              // CAPA 1: MAPA VISUAL
              InteractiveViewer(
                transformationController: _controller,
                boundaryMargin: const EdgeInsets.all(2000),
                minScale: 0.1,
                maxScale: 2.0,
                constrained: false,
                panEnabled: !modoAutomatico,
                scaleEnabled: !modoAutomatico,
                child: SizedBox(
                  width: 5000,
                  height: 5000,
                  child: Stack(
                    alignment: Alignment.center,
                    clipBehavior: Clip.none,
                    children: [
                      // LÍNEAS
                      ...nodosVisibles.map((nodo) {
                        if (nodo.padreX == null) return const SizedBox();
                        Color colorDeLaLinea = obtenerColorPorRanking(nodo.rankingCalculado, nodo.data.tipo);
                        double midYUnificado = midYsPorPadre[nodo.padreId] ?? (nodo.padreY! + 2500 + 100 + 50);

                        return Positioned.fill(
                          key: Key("linea_${nodo.id}"),
                          child: AnimacionEntrada(
                            esLinea: true,
                            delay: 0,
                            child: CustomPaint(
                              painter: PintorDeLineas(
                                inicioX: nodo.padreX! + 2500,
                                inicioY: nodo.padreY! + 2500,
                                finX: nodo.x + 2500,
                                finY: nodo.y + 2500,
                                midYFijo: midYUnificado,
                                colorLinea: colorDeLaLinea,
                              ),
                            ),
                          ),
                        );
                      }),
                      // NODOS
                      ...nodosVisibles.map((nodo) {
                        bool tieneNota = notasDelAlgoritmo.any((n) => n.nodoId == nodo.id);
                        return Positioned(
                          key: Key("nodo_${nodo.id}"),
                          left: nodo.x + 2500 - 120,
                          top: nodo.y + 2500,
                          child: AnimacionEntrada(
                            esLinea: false,
                            delay: 30,
                            child: GestureDetector(
                              onTap: () => revelarHijos(nodo),
                              child: _ConstruirTarjetaNodo(
                                nodo: nodo,
                                tieneNota: tieneNota,
                                onNotaTap: () => _abrirCrearNotaNodo(nodo.id, nodo.data.texto),
                              ),
                            ),
                          ),
                        );
                      }),
                    ],
                  ),
                ),
              ),

              // CAPA 2: CONTROLES DE NAVEGACIÓN (Flechas)
              if (modoAutomatico && _ultimoGrupoHijos.isNotEmpty)
                Positioned(
                  left: 20,
                  bottom: 20,
                  child: Container(
                    padding: const EdgeInsets.symmetric(horizontal: 10, vertical: 5),
                    decoration: BoxDecoration(
                      color: Colors.white.withOpacity(0.9),
                      borderRadius: BorderRadius.circular(30),
                      boxShadow: [BoxShadow(color: Colors.black12, blurRadius: 10)],
                    ),
                    child: Row(
                      children: [
                        IconButton(
                          icon: const Icon(Icons.arrow_back_ios, color: Colors.teal),
                          tooltip: "Anterior",
                          onPressed: () => _enfocarHijoEspecifico(_indiceHijoNavegacion - 1),
                        ),
                        Text(
                          _indiceHijoNavegacion == -1
                              ? "Vista Grupal"
                              : "${_indiceHijoNavegacion + 1}/${_ultimoGrupoHijos.length}",
                          style: const TextStyle(fontWeight: FontWeight.bold, color: Colors.teal),
                        ),
                        IconButton(
                          icon: const Icon(Icons.arrow_forward_ios, color: Colors.teal),
                          tooltip: "Siguiente",
                          onPressed: () => _enfocarHijoEspecifico(_indiceHijoNavegacion + 1),
                        ),
                      ],
                    ),
                  ),
                ),

              // CAPA 3: SLIDER DE ZOOM
              if (modoAutomatico)
                Positioned(
                  right: 10,
                  bottom: 180,
                  child: Container(
                    height: 200,
                    width: 50,
                    decoration: BoxDecoration(
                      color: Colors.white.withOpacity(0.9),
                      borderRadius: BorderRadius.circular(25),
                      boxShadow: [const BoxShadow(color: Colors.black12, blurRadius: 10)],
                    ),
                    child: Padding(
                      padding: const EdgeInsets.symmetric(vertical: 15),
                      child: Column(
                        mainAxisAlignment: MainAxisAlignment.spaceBetween,
                        children: [
                          const Icon(Icons.zoom_in, color: Colors.teal, size: 24),
                          Expanded(
                            child: RotatedBox(
                              quarterTurns: 3,
                              child: Slider(
                                value: _zoomLevelActual.clamp(0.2, 2.0),
                                min: 0.2,
                                max: 2.0,
                                activeColor: Colors.teal,
                                inactiveColor: Colors.teal.shade50,
                                onChanged: (val) => _cambiarZoomManual(val),
                              ),
                            ),
                          ),
                          const Icon(Icons.zoom_out, color: Colors.teal, size: 24),
                        ],
                      ),
                    ),
                  ),
                ),
            ],
          );
        },
      ),
    );
  }
}

class NodoEnElMapa {
  final String id;
  final NodoAlgoritmo data;
  final double x;
  final double y;
  final int nivel;
  final double? padreX;
  final double? padreY;
  final String? textoConector;
  final String? padreId;
  final int rankingCalculado;
  final int? filtroHijoIndex;

  // Propiedad para resaltar el nodo destino (Deep Linking)
  final bool esDestino;
  bool yaRevelado;

  NodoEnElMapa({
    required this.id,
    required this.data,
    required this.x,
    required this.y,
    required this.nivel,
    this.padreX,
    this.padreY,
    this.textoConector,
    this.padreId,
    this.rankingCalculado = 0,
    this.filtroHijoIndex,
    this.esDestino = false,
    this.yaRevelado = false,
  });

  double desplazamientoX = 0;
}

class _ConstruirTarjetaNodo extends StatelessWidget {
  final NodoEnElMapa nodo;
  final bool tieneNota;
  final VoidCallback onNotaTap;

  const _ConstruirTarjetaNodo({required this.nodo, required this.tieneNota, required this.onNotaTap});

  Color _colorFondo() {
    if (nodo.esDestino) return Colors.deepPurple.shade50;
    switch (nodo.rankingCalculado) {
      case 1: return Colors.blue.shade50;
      case 2: return Colors.green.shade50;
      case 3: return Colors.amber.shade50;
      default: return Colors.white;
    }
  }

  Color _colorBorde() {
    if (nodo.esDestino) return Colors.deepPurple;
    return obtenerColorPorRanking(nodo.rankingCalculado, nodo.data.tipo);
  }

  String _obtenerTituloRanking() {
    switch (nodo.rankingCalculado) {
      case 1: return "Opción con más evidencia";
      case 2: return "Segunda opción";
      case 3: return "Tercera opción";
      default: return "";
    }
  }

  void _mostrarImagenZoom(BuildContext context, String nombreImagen) {
    showDialog(
      context: context,
      barrierColor: Colors.black.withOpacity(0.9),
      builder: (context) {
        return Dialog(
          backgroundColor: Colors.transparent,
          insetPadding: EdgeInsets.zero,
          child: Stack(
            alignment: Alignment.center,
            children: [
              InteractiveViewer(
                panEnabled: true,
                boundaryMargin: const EdgeInsets.all(20),
                minScale: 0.5,
                maxScale: 4.0,
                child: UniversalImage(
                  ruta: nombreImagen.startsWith("http") ? nombreImagen : "assets/imagenes/$nombreImagen",
                  fit: BoxFit.contain,
                ),
              ),
              Positioned(
                top: 40,
                right: 20,
                child: IconButton(
                  icon: const Icon(Icons.close, color: Colors.white, size: 30),
                  onPressed: () => Navigator.pop(context),
                ),
              ),
            ],
          ),
        );
      },
    );
  }

  void _irAEnlace(BuildContext context, EnlaceAlgoritmo enlace) {
    Navigator.push(
      context,
      MaterialPageRoute(
        builder: (context) => MapaVisual(archivoJson: enlace.archivo, nodoInicialOverride: enlace.nodoId),
      ),
    );
  }

  @override
  Widget build(BuildContext context) {
    bool esResultado = nodo.data.tipo == 'resultado';
    bool tieneReferencias = nodo.data.referencias.isNotEmpty;
    bool tieneEnlaces = nodo.data.enlaces.isNotEmpty;
    String tituloRanking = _obtenerTituloRanking();

    // Etiqueta especial si es destino (Deep Linking)
    if (nodo.esDestino) tituloRanking = "📍 AQUÍ ESTÁ LO QUE BUSCAS";

    // ---> 1. MAGIA DE FORMATO (Viñetas y Separación de Pregunta) <---
    String formatearTexto(String original) {
      // 1. Cambia guiones por viñetas al inicio de línea
      String mod = original.replaceAll(RegExp(r'^-\s*', multiLine: true), '•  ');
      // 2. Si hay un salto de línea seguido de un "¿", le añade un salto extra para separar la pregunta
      mod = mod.replaceAll('\n¿', '\n\n¿');
      return mod;
    }

    String textoFormateado = formatearTexto(nodo.data.texto);

    // ---> 2. PARSEADOR DE NEGRITAS (**texto**) <---
    Widget construirTextoConFormato(String texto) {
      List<InlineSpan> spans = [];
      List<String> partes = texto.split('**');

      for (int i = 0; i < partes.length; i++) {
        if (i % 2 == 1) {
          // Texto dentro de los asteriscos dobles (Negrita)
          spans.add(TextSpan(
            text: partes[i],
            style: const TextStyle(fontWeight: FontWeight.w900, color: Colors.black),
          ));
        } else {
          // Texto normal
          spans.add(TextSpan(text: partes[i]));
        }
      }

      return RichText(
        textAlign: TextAlign.center,
        text: TextSpan(
          // Estilo base general del texto
          style: const TextStyle(
            fontSize: 16,
            height: 1.35,
            fontWeight: FontWeight.w500,
            color: Colors.black87,
          ),
          children: spans,
        ),
      );
    }
    // ----------------------------------------------------
    bool esFinal = nodo.data.opciones.isEmpty;
    return Column(
      children: [
        // --- 1. CONECTOR (FLECHA / TEXTO) ---
        if (nodo.textoConector != null)
          Container(
            padding: const EdgeInsets.symmetric(horizontal: 10, vertical: 6),
            decoration: BoxDecoration(
              color: _colorFondo(),
              borderRadius: BorderRadius.circular(6),
              border: Border.all(color: _colorBorde(), width: 2),
            ),
            constraints: const BoxConstraints(maxWidth: 200),
            child: Text(
              nodo.textoConector!,
              textAlign: TextAlign.center,
              style: const TextStyle(fontSize: 13.5, fontWeight: FontWeight.bold, color: Colors.black87),
            ),
          ),

        if (nodo.textoConector != null) Container(height: 8, width: 2, color: _colorBorde()),

        // --- 2. NODO PRINCIPAL CON BOTÓN FLOTANTE ---
        Stack(
          clipBehavior: Clip.none, // Permite que el botón circular se salga de la caja
          children: [

            // A. CAJA DEL NODO
            Container(
              width: 250,
              decoration: BoxDecoration(
                color: _colorFondo(),
                borderRadius: BorderRadius.circular(16),
                border: Border.all(color: _colorBorde(), width: nodo.esDestino ? 3 : 2),
                boxShadow: [
                  BoxShadow(
                    blurRadius: nodo.esDestino ? 15 : 5,
                    color: nodo.esDestino ? Colors.purple.withOpacity(0.3) : Colors.black.withOpacity(0.1),
                    offset: const Offset(0, 3),
                  ),
                ],
              ),
              child: Padding(
                padding: const EdgeInsets.fromLTRB(14, 18, 14, 14),
                child: Column(
                  children: [

                    // Título de ranking (Opcional)
                    if (tituloRanking.isNotEmpty)
                      Padding(
                        padding: const EdgeInsets.only(bottom: 8.0),
                        child: Text(
                          tituloRanking.toUpperCase(),
                          textAlign: TextAlign.center,
                          style: TextStyle(
                            fontSize: nodo.esDestino ? 11.5 : 10.5,
                            fontWeight: FontWeight.w900,
                            color: _colorBorde(),
                            letterSpacing: 0.5,
                          ),
                        ),
                      ),

                    // TEXTO CENTRAL DEL NODO CON FORMATO (NEGRITAS Y VIÑETAS)
                    construirTextoConFormato(textoFormateado),

                    // BOTÓN REFERENCIAS (Reubicado debajo del texto)
                    if (tieneReferencias)
                      Padding(
                        padding: const EdgeInsets.only(top: 10.0),
                        child: BotonReferencias(listaReferencias: nodo.data.referencias),
                      ),

                    // BOTÓN CALCULADORA
                    if (nodo.data.calculadoraArchivo != null)
                      Padding(
                        padding: const EdgeInsets.only(top: 12.0),
                        child: SizedBox(
                          height: 38,
                          child: ElevatedButton.icon(
                            icon: const Icon(Icons.calculate, size: 18),
                            label: const Text("Abrir Escala", style: TextStyle(fontSize: 14)),
                            style: ElevatedButton.styleFrom(
                              backgroundColor: Colors.white,
                              foregroundColor: Colors.indigo,
                              elevation: 1,
                              side: const BorderSide(color: Colors.indigo, width: 1),
                            ),
                            onPressed: () async {
                              final calcId = nodo.data.calculadoraArchivo!;

                              showDialog(
                                context: context,
                                barrierDismissible: false,
                                builder: (c) => const Center(child: CircularProgressIndicator(color: Colors.indigo)),
                              );

                              try {
                                if (calcId == 'antropometria') {
                                  Navigator.pop(context);
                                  Navigator.push(context, MaterialPageRoute(builder: (context) => AntropometriaScreen()));
                                  return;
                                }
                                if (calcId == 'presion_arterial') {
                                  Navigator.pop(context);
                                  Navigator.push(context, MaterialPageRoute(builder: (context) => PresionArterialScreen()));
                                  return;
                                }

                                final listaDinamica = ContentManager().menuCalculadoras;
                                String? urlArchivo;
                                for (var item in listaDinamica) {
                                  if (item['id'] == calcId) {
                                    urlArchivo = item['archivo'];
                                    break;
                                  }
                                }

                                DatosEscala datosCalc;
                                if (urlArchivo != null) {
                                  final map = await ContentManager().cargarDatosCalculadora(urlArchivo);
                                  datosCalc = DatosEscala.fromJson(map);
                                } else {
                                  datosCalc = await CargadorAssets.cargarEscala(calcId);
                                }

                                if (!context.mounted) return;
                                Navigator.pop(context);

                                showGeneralDialog(
                                  context: context,
                                  barrierDismissible: true,
                                  barrierLabel: 'Cerrar',
                                  barrierColor: Colors.black.withOpacity(0.4),
                                  transitionDuration: const Duration(milliseconds: 200),
                                  pageBuilder: (context, animation, secondaryAnimation) {
                                    return CalculadoraWidget(
                                      datos: datosCalc,
                                      mostrarBotones: true,
                                      onResultadoSeleccionado: (index) {
                                        context.findAncestorStateOfType<_MapaVisualState>()?.aplicarFiltro(nodo, index);
                                      },
                                    );
                                  },
                                  transitionBuilder: (context, animation, secondaryAnimation, child) {
                                    return BackdropFilter(
                                      filter: ImageFilter.blur(sigmaX: 1.5 * animation.value, sigmaY: 1.5 * animation.value),
                                      child: FadeTransition(
                                        opacity: animation,
                                        child: ScaleTransition(
                                          scale: Tween<double>(begin: 0.95, end: 1.0).animate(
                                            CurvedAnimation(parent: animation, curve: Curves.easeOutCubic),
                                          ),
                                          child: child,
                                        ),
                                      ),
                                    );
                                  },
                                );

                              } catch (e) {
                                if (context.mounted) Navigator.pop(context);
                                ScaffoldMessenger.of(context).showSnackBar(SnackBar(content: Text('Error al abrir la calculadora: $e')));
                              }
                            },
                          ),
                        ),
                      ),

                    // IMAGEN CLÍNICA
                    if (nodo.data.imagenClinica != null)
                      Padding(
                        padding: const EdgeInsets.only(top: 12.0),
                        child: GestureDetector(
                          onTap: () => _mostrarImagenZoom(context, nodo.data.imagenClinica!),
                          child: Container(
                            height: 130,
                            width: double.infinity,
                            decoration: BoxDecoration(
                              borderRadius: BorderRadius.circular(12),
                              border: Border.all(color: _colorBorde(), width: 2),
                              color: Colors.white,
                            ),
                            child: ClipRRect(
                              borderRadius: BorderRadius.circular(10),
                              child: Stack(
                                fit: StackFit.expand,
                                children: [
                                  UniversalImage(
                                    ruta: nodo.data.imagenClinica!.startsWith("http")
                                        ? nodo.data.imagenClinica!
                                        : "assets/imagenes/${nodo.data.imagenClinica}",
                                    fit: BoxFit.cover,
                                  ),
                                  const Center(child: Icon(Icons.zoom_in, color: Colors.white70, size: 35)),
                                ],
                              ),
                            ),
                          ),
                        ),
                      ),

                    // ENLACES A OTROS ALGORITMOS
                    if (tieneEnlaces)
                      Padding(
                        padding: const EdgeInsets.only(top: 12),
                        child: Column(
                          children: nodo.data.enlaces.map((enlace) {
                            return Padding(
                              padding: const EdgeInsets.only(bottom: 6),
                              child: OutlinedButton.icon(
                                icon: const Icon(Icons.open_in_new, size: 16),
                                label: Text(enlace.texto, style: const TextStyle(fontSize: 12.5), textAlign: TextAlign.center),
                                style: OutlinedButton.styleFrom(
                                  foregroundColor: Colors.indigo,
                                  side: const BorderSide(color: Colors.indigo, width: 1.5),
                                  visualDensity: VisualDensity.compact,
                                  minimumSize: const Size(double.infinity, 35),
                                ),
                                onPressed: () => _irAEnlace(context, enlace),
                              ),
                            );
                          }).toList(),
                        ),
                      ),

                    // FLECHITA DE EXPANSIÓN (Si no es final y no está revelado)
                    if (!esResultado && !nodo.yaRevelado)
                      const Padding(
                        padding: EdgeInsets.only(top: 12.0),
                        child: Icon(Icons.arrow_drop_down_circle, color: Colors.blue, size: 24),
                      ),
                    if (esFinal)
                      Padding(
                        padding: const EdgeInsets.only(top: 16.0),
                        child: ElevatedButton(
                          style: ElevatedButton.styleFrom(
                            backgroundColor: Colors.teal,
                            foregroundColor: Colors.white,
                            elevation: 0,
                          ),
                          onPressed: () {
                            // Cierra el algoritmo limpiamente y evita la pantalla roja
                            Navigator.pop(context);
                          },
                          child: const Text("Finalizar Algoritmo"),
                        ),
                      ),
                  ],
                ),
              ),
            ),

            // B. EL BOTÓN FLOTANTE CÍRCULO (Notas)
            Positioned(
              top: -14,
              right: -14,
              child: Material(
                color: Colors.white,
                elevation: 4,
                shadowColor: Colors.black54,
                shape: const CircleBorder(),
                child: InkWell(
                  customBorder: const CircleBorder(),
                  onTap: onNotaTap,
                  child: Container(
                    padding: const EdgeInsets.all(8),
                    decoration: BoxDecoration(
                      shape: BoxShape.circle,
                      border: Border.all(
                        color: tieneNota ? Colors.amber.shade700 : Colors.grey.shade300,
                        width: 1.5,
                      ),
                    ),
                    child: Icon(
                      tieneNota ? Icons.note_alt : Icons.note_add_outlined,
                      size: 20,
                      color: tieneNota ? Colors.amber.shade800 : Colors.grey.shade600,
                    ),
                  ),
                ),
              ),
            ),

          ],
        ),
      ],
    );
  }
}

class PintorDeLineas extends CustomPainter {
  final double inicioX, inicioY, finX, finY;
  final double midYFijo;
  final Color colorLinea;

  PintorDeLineas({
    required this.inicioX,
    required this.inicioY,
    required this.finX,
    required this.finY,
    required this.midYFijo,
    required this.colorLinea,
  });

  @override
  void paint(Canvas canvas, Size size) {
    double startX = inicioX;
    double startY = inicioY + 100; // Ajuste desde la tarjeta
    double targetX = finX;
    double targetY = finY;
    double midY = midYFijo;

    // 1. CREAR EL PATH (El recorrido de la línea)
    final path = Path();
    path.moveTo(startX, startY);
    path.lineTo(startX, midY - 15);

    bool esLineaRecta = (startX - targetX).abs() < 10;
    if (esLineaRecta) {
      path.lineTo(startX, targetY);
    } else {
      path.quadraticBezierTo(startX, midY, startX + (targetX > startX ? 15 : -15), midY);
      path.lineTo(targetX + (targetX > startX ? -15 : 15), midY);
      path.quadraticBezierTo(targetX, midY, targetX, midY + 15);
      path.lineTo(targetX, targetY);
    }

    // 2. CREAR SOMBRA (Le da efecto 3D)
    final shadowPaint = Paint()
      ..color = Colors.black.withOpacity(0.08) // Sombra suave
      ..strokeWidth = 3.5
      ..style = PaintingStyle.stroke
      ..strokeCap = StrokeCap.round
      ..maskFilter = const MaskFilter.blur(BlurStyle.normal, 4.0); // Efecto difuminado

    // 3. CREAR GRADIENTE PARA LA LÍNEA PRINCIPAL
    // Calcula el área que ocupa la línea para aplicar el gradiente
    final rect = Rect.fromPoints(Offset(startX, startY), Offset(targetX, targetY));
    final gradient = LinearGradient(
      begin: Alignment.topCenter,
      end: Alignment.bottomCenter,
      colors: [
        colorLinea.withOpacity(0.3), // Arriba nace semi-transparente
        colorLinea,                  // Abajo llega con color sólido
      ],
    );

    final paint = Paint()
      ..shader = gradient.createShader(rect) // Aplicamos el gradiente
      ..strokeWidth = 3.5 // Hacemos la línea levemente más gruesa (antes 2.5)
      ..style = PaintingStyle.stroke
      ..strokeCap = StrokeCap.round;

    // 4. DIBUJAR (Primero la sombra desplazada hacia abajo, luego la línea a color)
    canvas.drawPath(path.shift(const Offset(0, 3)), shadowPaint);
    canvas.drawPath(path, paint);
  }

  @override
  bool shouldRepaint(covariant PintorDeLineas oldDelegate) {
    return oldDelegate.inicioX != inicioX ||
        oldDelegate.finX != finX ||
        oldDelegate.midYFijo != midYFijo ||
        oldDelegate.colorLinea != colorLinea;
  }
}

Color obtenerColorPorRanking(int ranking, String tipoNodo) {
  switch (ranking) {
    case 1:
      return Colors.blue;
    case 2:
      return Colors.green;
    case 3:
      return Colors.amber;
    default:
      if (tipoNodo == 'resultado') {
        return Colors.teal;
      } else {
        // ADIÓS AL GRIS PLANO. Hola Índigo suave y elegante.
        return Colors.indigo.shade300;
      }
  }
}



class AnimacionEntrada extends StatefulWidget {
  final Widget child;
  final int delay;
  final bool esLinea;

  const AnimacionEntrada({super.key, required this.child, this.delay = 0, this.esLinea = false});

  @override
  State<AnimacionEntrada> createState() => _AnimacionEntradaState();
}

class _AnimacionEntradaState extends State<AnimacionEntrada> with SingleTickerProviderStateMixin {
  late AnimationController _controller;
  late Animation<double> _scaleAnim;
  late Animation<double> _fadeAnim;
  late Animation<Offset> _slideAnim;

  @override
  void initState() {
    super.initState();
    _controller = AnimationController(vsync: this, duration: const Duration(milliseconds: 200));

    if (!widget.esLinea) {
      _scaleAnim = Tween<double>(begin: 0.0, end: 1.0).animate(CurvedAnimation(parent: _controller, curve: Curves.easeOut));
      _slideAnim = Tween<Offset>(
        begin: const Offset(0, -0.5),
        end: Offset.zero,
      ).animate(CurvedAnimation(parent: _controller, curve: Curves.easeOutQuad));
    } else {
      _scaleAnim = Tween<double>(begin: 0.0, end: 1.0).animate(CurvedAnimation(parent: _controller, curve: Curves.easeOut));
      _slideAnim = Tween<Offset>(begin: Offset.zero, end: Offset.zero).animate(_controller);
    }

    _fadeAnim = Tween<double>(begin: 0.0, end: 1.0).animate(CurvedAnimation(parent: _controller, curve: Curves.easeIn));

    Future.delayed(Duration(milliseconds: widget.delay), () {
      if (mounted) _controller.forward();
    });
  }

  @override
  void dispose() {
    _controller.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return FadeTransition(
      opacity: _fadeAnim,
      child: SlideTransition(
        position: _slideAnim,
        child: ScaleTransition(scale: widget.esLinea ? const AlwaysStoppedAnimation(1.0) : _scaleAnim, child: widget.child),
      ),
    );
  }
}
